            "auth": {
              "type": "apikey",
              "key": "X-Auth-Token",
              "value": "{{X-Auth-Token}}",
              "placement": "header"
            }
          },
          "docs": "Add new ACL rules for a specific cluster."
        },
        {
          "info": {
            "name": "Set new ACLs",
