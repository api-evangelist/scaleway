          "docs": "Retrieve the list of blocklists."
        },
        {
          "info": {
            "name": "Bulk create blocklists",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.scaleway.com/transactional-email/v1alpha1/regions/:region/blocklists",
