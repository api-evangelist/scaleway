{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/scaleway.instance.v1.ListServersTypesResponse",
  "title": "scaleway.instance.v1.ListServersTypesResponse",
  "type": "object",
  "properties": {
    "servers": {
