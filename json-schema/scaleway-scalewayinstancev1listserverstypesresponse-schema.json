                "l_ssd": {
                  "type": "object",
                  "description": "Local SSD volumes.",
                  "properties": {
                    "min_size": {
                      "type": "integer",
                      "description": "Minimum volume size in bytes. (in bytes)",
                      "format": "uint64"
                    },
                    "max_size": {
                      "type": "integer",
                      "description": "Maximum volume size in bytes. (in bytes)",
                      "format": "uint64"
                    }
                  },
                  "x-properties-order": [
                    "min_size",
                    "max_size"
                  ]
                }
              },
              "x-properties-order": [
                "l_ssd"
              ]
            },
            "volumes_constraint": {
              "type": "object",
              "description": "Initial volume constraints.",
              "properties": {
                "min_size": {
                  "type": "integer",
                  "description": "Minimum volume size in bytes. (in bytes)",
                  "format": "uint64"
                },
                "max_size": {
                  "type": "integer",
                  "description": "Maximum volume size in bytes. (in bytes)",
                  "format": "uint64"
                }
              },
              "x-properties-order": [
                "min_size",
                "max_size"
              ]
            },
            "ncpus": {
