    },
    "unlimited": {
      "type": "boolean",
      "description": "Whether or not the quota per locality is unlimited.",
      "nullable": true,
      "x-one-of": "value"
    }
  },
  "x-properties-order": [
    "global",
    "region",
    "zone",
    "limit",
    "unlimited"
  ]
