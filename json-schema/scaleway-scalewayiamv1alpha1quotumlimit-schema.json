{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/scaleway.iam.v1alpha1.Quotum.Limit",
  "title": "scaleway.iam.v1alpha1.Quotum.Limit",
  "type": "object",
  "properties": {
    "global": {
      "type": "boolean",
